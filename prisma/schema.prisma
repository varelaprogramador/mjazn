generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// Categorias (dinâmicas)
// =============================================

model ProductCategory {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  color     String    @default("#FF4500") // hex para badge
  image     String?   // URL da imagem de capa da categoria
  description String? // descrição curta exibida no card
  products  Product[]

  createdAt DateTime  @default(now())

  @@index([slug])
}

// =============================================
// Produtos
// =============================================

model Product {
  id               String           @id @default(cuid())
  slug             String           @unique
  name             String
  price            Int
  originalPrice    Int?
  description      String
  shortDescription String
  categoryId       String
  category         ProductCategory  @relation(fields: [categoryId], references: [id])
  images           String[]
  rating           Float            @default(0)
  reviewCount      Int              @default(0)
  isNew            Boolean          @default(false)
  isLimited        Boolean          @default(false)
  tags             String[]
  dropId           String?
  drop             Drop?            @relation(fields: [dropId], references: [id])
  variants         ProductVariant[]
  orderItems       OrderItem[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([categoryId])
  @@index([dropId])
  @@index([slug])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String
  color     String
  colorHex  String
  stock     Int     @default(0)

  @@unique([productId, size, color])
  @@index([productId])
}

// =============================================
// Drops / Coleções
// =============================================

model Drop {
  id             String    @id @default(cuid())
  name           String
  tagline        String
  description    String
  startDate      DateTime
  endDate        DateTime
  stockLimit     Int
  stockRemaining Int
  isActive       Boolean   @default(false)
  products       Product[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([isActive])
}

// =============================================
// Pedidos
// =============================================

model Order {
  id              String        @id @default(cuid())
  status          OrderStatus   @default(pending)
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  customerName    String
  customerEmail   String
  customerPhone   String
  customerCpf     String
  totalPrice      Int
  street          String
  number          String
  complement      String?
  neighborhood    String
  city            String
  state           String
  zipCode         String
  paymentMethod   PaymentMethod @default(PIX)
  paymentStatus   PaymentStatus @default(PENDING)
  asaasPaymentId  String?
  asaasCustomerId String?
  items           OrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([asaasPaymentId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  size      String
  color     String
  quantity  Int
  price     Int

  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

// =============================================
// Better Auth
// =============================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  phone         String?
  role          String?   @default("user")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  orders        Order[]
  addresses     CustomerAddress[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model CustomerAddress {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String   @default("Casa")
  recipientName String
  street        String
  number        String
  complement    String?
  neighborhood  String
  city          String
  state         String
  zipCode       String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("customer_addresses")
}

// =============================================
// Depoimentos
// =============================================

model Testimonial {
  id             String   @id @default(cuid())
  name           String
  location       String
  rating         Int
  text           String
  productName    String
  avatarInitials String
  createdAt      DateTime @default(now())
}
